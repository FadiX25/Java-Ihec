<!-- ================================================================
     OPTION A: Just the dependencies to ADD to an existing pom.xml
     ================================================================ -->

<dependencies>

    <!-- Firebase Admin SDK — gives you Firestore, Auth, etc. -->
    <dependency>
        <groupId>com.google.firebase</groupId>
        <artifactId>firebase-admin</artifactId>
        <version>9.2.0</version>
    </dependency>

    <!-- Needed by firebase-admin for HTTP transport -->
    <dependency>
        <groupId>com.google.http-client</groupId>
        <artifactId>google-http-client-gson</artifactId>
        <version>1.43.3</version>
    </dependency>

</dependencies>


